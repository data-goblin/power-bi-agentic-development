{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat > /dev/null; jq -n '{hookSpecificOutput:{hookEventName:\"PreToolUse\",permissionDecision:\"deny\",permissionDecisionReason:\"Use uv instead of pip.\"}}'",
            "if": "Bash(pip *)"
          },
          {
            "type": "command",
            "command": "cat > /dev/null; jq -n '{hookSpecificOutput:{hookEventName:\"PreToolUse\",permissionDecision:\"deny\",permissionDecisionReason:\"Use uv instead of pip3.\"}}'",
            "if": "Bash(pip3 *)"
          }
        ]
      }
    ]
  }
}
